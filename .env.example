# Google OAuth Configuration for BugDocs
# Copy this file to .env and fill in your actual credentials
# Get credentials from: https://console.cloud.google.com/apis/credentials

GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret-here

# Redirect URI - will auto-detect production vs local if not set
# Local: http://localhost/BugRicer/backend/api/oauth/callback
# Production: https://bugbackend.bugricer.com/api/oauth/callback
GOOGLE_REDIRECT_URI=

# Database Configuration (optional - uses defaults from database.php if not set)
# DB_HOST=localhost
# DB_NAME=u262074081_bugfixer_db
# DB_USER=root
# DB_PASS=

# Outgoing email (PHPMailer) — required for magic links, password reset, notifications
# Gmail: use an App Password (Google Account → Security → 2-Step Verification → App passwords)
# SMTP_PASS may contain spaces; do not wrap the whole line in quotes unless your parser requires it
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-account@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM_EMAIL=your-account@gmail.com
# SMTP_FROM_NAME=BugRicer

# BugRicer Notify API - WhatsApp notifications (optional - uses defaults from utils/whatsapp.php)
# Use international format WITHOUT + sign (e.g. 919497792540 for India)
# WHATSAPP_API_KEY=c9b175ddaec8904c2c26cc1e6ca2953c
# WHATSAPP_ADMIN_NUMBERS=919497792540,918848676627
