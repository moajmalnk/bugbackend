GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://bugbackend.bugricer.com/api/oauth/callback

# BugRicer Notify API - WhatsApp notifications (optional)
WHATSAPP_API_KEY=your-notify-api-key
WHATSAPP_ADMIN_NUMBERS=91XXXXXXXXXX

# Outgoing email (Gmail: use App Password, not your normal password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=BugRicer

# Firebase Admin SDK (FCM push) — use server file path on Hostinger
FIREBASE_SERVICE_ACCOUNT_PATH=/home/USER/domains/bugricer.com/public_html/bugbackend/config/firebase-service-account.json

# Bump after clearing user_fcm_tokens so clients re-register on next login
FCM_TOKEN_EPOCH=1

