#   public_html/bugbackend_vendor/
# (outside this git repo so deploys never delete them)
vendor/
composer.lock
vendor-firebase-complete.zip
vendor.zip

# IDE specific files
.idea/
.vscode/
*.swp
*.swo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db .env

# Database dumps (may contain secrets)
currentdb.sql
*.sql.backup
*.sql.bak
